# HackLet League — Caddy config.
# SITE_ADDRESS and ACME_EMAIL come from .env via docker-compose. A real domain in
# SITE_ADDRESS gets automatic Let's Encrypt TLS; ":80" serves plain HTTP (local).

{
	email {$ACME_EMAIL}
}

{$SITE_ADDRESS} {
	encode zstd gzip

	# Django backend
	handle /api/* {
		reverse_proxy backend:8000
	}
	handle /admin/* {
		reverse_proxy backend:8000
	}
	handle /static/* {
		reverse_proxy backend:8000
	}

	# Static landing page (everything else)
	handle {
		root * /srv
		file_server
	}

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}
