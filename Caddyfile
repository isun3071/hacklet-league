# HackLet League — Caddy config.
# Serves the app on TWO addresses at once (both from .env):
#   SITE_ADDRESS — your public domain -> automatic HTTPS (cert issues once DNS
#                  resolves to this box and 80/443 are reachable).
#   LAN_ADDRESS  — an explicit http:// host (e.g. a LAN IP) -> plain HTTP, and
#                  because the scheme is http:// Caddy does NOT redirect it to HTTPS.

{
	email {$ACME_EMAIL}
}

# Shared routing for every site below.
(app) {
	encode zstd gzip

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	# One ordered route so the admin guards below evaluate top-down (handle/respond
	# ordering is otherwise directive-order dependent, which is too subtle to trust here).
	route {
		# --- Admin portal hardening (see DEPLOY.md "Securing the admin portal") ---
		# The admin lives at a secret slug ($ADMIN_PATH), NOT /admin, and is reachable
		# ONLY from the Tailscale tailnet (100.64.0.0/10) or loopback. Every other
		# caller gets a bare 404 — indistinguishable from a path that doesn't exist.
		# This Caddy runs on the HOST network (see docker-compose.yml), so remote_ip is
		# the TRUE client IP. That's essential: on a Docker bridge network, NAT
		# masquerades tailnet traffic (destined to the VM's own tailnet IP) as a 172.x
		# address, so the gate could never match. Upstreams are likewise reached over
		# loopback-published ports. If a CDN is ever fronted, switch remote_ip ->
		# client_ip + trusted_proxies, else it becomes spoofable via X-Forwarded-For.
		@admin_offnet {
			path /{$ADMIN_PATH}/*
			not remote_ip 100.64.0.0/10 127.0.0.1/8 ::1
		}
		respond @admin_offnet 404

		@admin path /{$ADMIN_PATH}/*
		reverse_proxy @admin 127.0.0.1:8000

		# Django backend (API, static assets, allauth OAuth callbacks).
		@backend path /api/* /static/* /_allauth/* /accounts/*
		reverse_proxy @backend 127.0.0.1:8000

		# Next.js frontend (everything else). The legacy /admin path lands here and
		# gets Next's ordinary 404 — no hint that a Django admin exists anywhere.
		reverse_proxy 127.0.0.1:3000
	}
}

# Public domain: automatic HTTPS.
{$SITE_ADDRESS} {
	import app
}

# Direct LAN / IP access over plain HTTP (no HTTPS redirect).
{$LAN_ADDRESS} {
	import app
}
