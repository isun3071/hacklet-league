# ---- HackLet League deployment config ----
# Copy to .env (gitignored) and fill in. .env is the ONLY file that differs
# between hosts. Values below show the PUBLIC-DOMAIN (production) setup;
# local-dev alternatives are noted in comments.
#
#   cp .env.example .env

# ===== Django =====
# Generate a strong key and NEVER commit the real one:
#   openssl rand -base64 48
SECRET_KEY=change-me-to-a-long-random-string

# Production = DEBUG off, secure cookies, HSTS, CSRF origin checks.
DJANGO_SETTINGS_MODULE=hacklet.settings.prod
#   Local dev instead:  DJANGO_SETTINGS_MODULE=hacklet.settings.dev

# Hosts Django will serve (comma-separated). Must include your domain.
# Add your LAN IP too (e.g. ...,10.0.0.x) if you want http://<ip> to serve
# public pages — but logged-in features need the HTTPS domain (secure cookies).
ALLOWED_HOSTS=hackletleague.com
#   Local dev instead:  ALLOWED_HOSTS=*

# Origins trusted for CSRF on writes (production; scheme required).
CSRF_TRUSTED_ORIGINS=https://hackletleague.com

# ===== Caddy / hosting =====
# Public domain -> automatic Let's Encrypt HTTPS.
SITE_ADDRESS=hackletleague.com
#   Local dev instead:  SITE_ADDRESS=http://localhost
# Extra plain-HTTP host for direct LAN access (no HTTPS redirect).
# Set to your VM's LAN IP, e.g. http://10.0.0.x  (kept generic here on purpose).
LAN_ADDRESS=http://localhost
# Real email for Let's Encrypt expiry notices.
ACME_EMAIL=you@example.com

# ===== PostgreSQL =====
# DB has no published host port (internal docker network only), so the default
# credentials are acceptable for now. NOTE: POSTGRES_PASSWORD only applies when
# the data volume is first created — to rotate it later you must ALTER the role
# (docker compose exec db psql -U hacklet -c "ALTER USER hacklet PASSWORD '...';")
# and update DATABASE_URL, not just edit this file.
POSTGRES_USER=hacklet
POSTGRES_PASSWORD=hacklet
POSTGRES_DB=hacklet
DATABASE_URL=postgres://hacklet:hacklet@db:5432/hacklet
