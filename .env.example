# ---- HackLet League deployment config ----
# Copy to .env (gitignored) and fill in. .env is the ONLY file that differs
# between hosts — that's what makes moving from the home VM to Hetzner seamless.
#
#   cp .env.example .env

# ---- Caddy / hosting ----
# Public address Caddy serves and provisions TLS for.
#   Production (real domain -> automatic HTTPS):   SITE_ADDRESS=hackletleague.com
#   Local / stealth (HTTP only, no certs issued):  SITE_ADDRESS=:80
SITE_ADDRESS=:80
# Email for Let's Encrypt notices (used only when SITE_ADDRESS is a real domain).
ACME_EMAIL=you@example.com

# ---- Django backend (Stage 1+) ----
# Generate a real key: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-long-random-string
# dev = DEBUG on, ALLOWED_HOSTS=*. Switch to hacklet.settings.prod at public launch.
DJANGO_SETTINGS_MODULE=hacklet.settings.dev
ALLOWED_HOSTS=*

# ---- PostgreSQL ----
POSTGRES_USER=hacklet
POSTGRES_PASSWORD=hacklet
POSTGRES_DB=hacklet
DATABASE_URL=postgres://hacklet:hacklet@db:5432/hacklet
