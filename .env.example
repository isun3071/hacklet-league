# ---- HackLet League deployment config ----
# Copy to .env (gitignored) and fill in. .env is the ONLY file that differs
# between hosts — that's what makes moving from the home VM to Hetzner seamless.
#
#   cp .env.example .env

# ---- Caddy / hosting ----
# Caddy serves the app on BOTH addresses below at once, so you can have HTTPS on
# a public domain and plain HTTP on a LAN IP simultaneously.
#
# SITE_ADDRESS: public domain -> automatic HTTPS (cert issues only once DNS points
#   to this box and 80/443 are reachable). For pure-local dev use http://localhost.
SITE_ADDRESS=http://localhost
# LAN_ADDRESS: an extra explicit-http:// host for direct access with no HTTPS
#   redirect (e.g. your VM's LAN IP: http://10.0.0.x). Defaults to http://localhost.
LAN_ADDRESS=http://127.0.0.1
# Email for Let's Encrypt notices (used only for the HTTPS domain).
ACME_EMAIL=you@example.com

# ---- Django backend (Stage 1+) ----
# Generate a real key: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-long-random-string
# dev = DEBUG on, ALLOWED_HOSTS=*. Switch to hacklet.settings.prod at public launch.
DJANGO_SETTINGS_MODULE=hacklet.settings.dev
ALLOWED_HOSTS=*

# ---- PostgreSQL ----
POSTGRES_USER=hacklet
POSTGRES_PASSWORD=hacklet
POSTGRES_DB=hacklet
DATABASE_URL=postgres://hacklet:hacklet@db:5432/hacklet
