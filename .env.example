# ---- HackLet League deployment config ----
# Copy to .env (which is gitignored) and fill in.
# .env is the ONLY file that differs between hosts — that's what makes moving
# from the home VM to Hetzner seamless.
#
#   cp .env.example .env

# Public address Caddy serves and provisions TLS for.
#   Production (real domain -> automatic HTTPS):   SITE_ADDRESS=hackletleague.com
#   Local testing (HTTP only, no certs issued):    SITE_ADDRESS=:80
SITE_ADDRESS=hackletleague.com

# Email for Let's Encrypt expiry/issuance notices (required for production TLS).
ACME_EMAIL=you@example.com
